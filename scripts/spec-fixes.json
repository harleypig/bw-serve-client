  "descriptions": {
    "description": "Add missing descriptions to schemas and properties",
    "schemas": {
      "item.template": "Represents a vault item (login, secure note, card, or identity)",
      "item.login": "Login credentials including URIs, username, password, and TOTP",
      "item.secureNote": "Secure note item type for storing text information",
      "item.card": "Credit card or payment card information",
      "item.identity": "Personal identity information (name, address, etc.)",
      "folder": "Vault folder for organizing items",
      "collection": "Organization collection for sharing items",
      "group": "Organization group for managing permissions",
      "uris": "URI/URL associated with a login item",
      "field": "Custom field attached to a vault item",
      "send.template": "Bitwarden Send for secure sharing",
      "send.text": "Text content for a Bitwarden Send",
      "status": "Status information about the Bitwarden CLI client",
      "lockunlock.success": "Response from lock/unlock operations",
      "deviceapprovalproperties": "Device approval request information",
      "deviceapprovallist": "List of device approval requests"
    },
    "properties": {
      "item.template": {
        "organizationId": "Organization ID if item belongs to an organization",
        "collectionIds": "Array of collection IDs for organization items",
        "folderId": "Folder ID for organizing the item",
        "type": "Type of vault item (1=login, 2=note, 3=card, 4=identity)",
        "name": "Display name of the vault item",
        "notes": "Free-form notes associated with the item",
        "favorite": "Whether the item is marked as a favorite",
        "fields": "Array of custom fields",
        "login": "Login-specific data (username, password, URIs, TOTP)",
        "secureNote": "Secure note data",
        "card": "Credit card data",
        "identity": "Identity data",
        "reprompt": "Master password re-prompt requirement (0=none, 1=required)"
      },
      "item.login": {
        "uris": "Array of URIs associated with this login",
        "username": "Username for the login",
        "password": "Password for the login",
        "totp": "TOTP secret for two-factor authentication"
      },
      "uris": {
        "match": "URI matching behavior (0=domain, 1=host, 2=startsWith, 3=exact, 4=regex, 5=never)",
        "uri": "The URI/URL value"
      },
      "field": {
        "name": "Name of the custom field",
        "value": "Value of the custom field",
        "type": "Field type (0=text, 1=hidden, 2=boolean, 3=linked)"
      },
      "folder": {
        "name": "Name of the folder"
      },
      "send.template": {
        "name": "Name of the Send",
        "notes": "Notes for the Send",
        "type": "Type of Send (0=text, 1=file)",
        "text": "Text content (for text Sends)",
        "file": "File content (for file Sends)",
        "maxAccessCount": "Maximum number of times the Send can be accessed",
        "deletionDate": "When the Send will be automatically deleted",
        "expirationDate": "When the Send will expire",
        "password": "Password required to access the Send",
        "disabled": "Whether the Send is disabled",
        "hideEmail": "Whether to hide the sender's email"
      }
    }
  },
  
  "parameter_fixes": {
    "description": "Fix parameter definitions and add missing ones",
    "global_parameters": {
      "ItemId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Unique identifier of the vault item",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "FolderId": {
        "name": "id", 
        "in": "path",
        "required": true,
        "description": "Unique identifier of the folder",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "SendId": {
        "name": "id",
        "in": "path", 
        "required": true,
        "description": "Unique identifier of the Send",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "OrganizationId": {
        "name": "organizationId",
        "in": "query",
        "required": true,
        "description": "Unique identifier of the organization",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    }
  }
}
